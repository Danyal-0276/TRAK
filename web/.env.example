# Optional: public web origin for share links (defaults to current origin in dev)
# VITE_PUBLIC_WEB_URL=https://trak-flax.vercel.app

# Production builds use web/.env.production (Render URL).

# Deployed API (production builds / Netlify) — required for production if apiBase has no fallback
VITE_API_URL=https://trak-backend-upip.onrender.com

# Local Vite dev → Render via proxy (avoids browser CORS; see vite.config.js)
VITE_API_URL=http://localhost:3000

# Local Django instead (no proxy needed):
# VITE_API_URL=http://127.0.0.1:8000

# Optional: real-time WebSocket notifications (requires daphne/ASGI — not runserver)
# VITE_ENABLE_NOTIFICATIONS_WS=true

# Optional: fake Tech News cards when API fails (off by default)
# VITE_ALLOW_MOCK_FEED=true

# Optional: API timeout ms (Render cold start — default 90000 in code)
# VITE_API_TIMEOUT_MS=90000

# Listen / TTS (first chunk can take minutes while models load — default 360000)
# VITE_TTS_PLAN_TIMEOUT_MS=120000
# VITE_TTS_CHUNK_TIMEOUT_MS=360000

# Article TTS (English / Urdu) is proxied by Django → Hugging Face urdu-tts-api.
# Backend: TTS_API_BASE_URL=https://abd8433-urdu-tts-api.hf.space (default)

# Firebase Web (from Firebase Console → Project settings → Your apps → Web)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=trak-46a8f.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=trak-46a8f
# VITE_FIREBASE_STORAGE_BUCKET=trak-46a8f.firebasestorage.app
# VITE_FIREBASE_MESSAGING_SENDER_ID=966052710818
# VITE_FIREBASE_APP_ID=
