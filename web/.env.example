# Copy to web/.env for local Vite dev (web/.env is gitignored).
# Production builds use web/.env.production + vercel.json → VPS.

# Production (Vercel): same-origin; /api proxied to VPS in vercel.json
# VITE_API_URL=https://trak-flax.vercel.app

# Local dev → Django via Vite proxy (see vite.config.js)
VITE_API_URL=http://localhost:3000

# Or direct local Django (no proxy):
# VITE_API_URL=http://127.0.0.1:8000

# Optional: public web URL for share links
# VITE_PUBLIC_WEB_URL=https://trak-flax.vercel.app

# Optional: real-time WebSocket notifications (requires daphne on backend)
# VITE_ENABLE_NOTIFICATIONS_WS=true

# Optional: API timeout ms (Render/VPS cold start — default 90000 in code)
# VITE_API_TIMEOUT_MS=90000

# Never enable in production — shows fake placeholder articles when API fails.
VITE_ALLOW_MOCK_FEED=false
