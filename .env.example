# TRAK monorepo — client API origins (not Django secrets; those live in Backend/TRAK_Backend/.env)
#
# Web production: web/.env.production → https://trak-flax.vercel.app (vercel.json proxies /api → VPS)
# Mobile production: src/config/api.production.js → http://167.86.110.151:8000 (committed)
# Mobile dev: copy src/config/api.local.example.js → api.local.js (gitignored)

# Web local dev (copy to web/.env)
# VITE_API_URL=http://localhost:3000

# VPS Django API (reference — mobile uses api.production.js)
# VPS_API=http://167.86.110.151:8000

# Mobile Wi‑Fi dev (physical device — match your PC ipconfig IPv4)
DEV_LAN_HOST=192.168.100.100
DEV_API_PORT=8000
