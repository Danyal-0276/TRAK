# TRAK monorepo — client API origin (not Django secrets; those live in TRAK-BACKEND/.env)
#
# Web: copy values into web/.env (Vite only exposes VITE_* vars)
# Mobile: copy API_BASE into src/config/api.local.js (see api.local.example.js)

# Production / Render Django API
VITE_API_URL=https://trak-backend-upip.onrender.com

# Local Django (web dev — pick one)
# VITE_API_URL=http://127.0.0.1:8000
# VITE_API_URL=http://localhost:3000

# Mobile Wi‑Fi dev (physical device — match your PC ipconfig IPv4)
DEV_LAN_HOST=192.168.100.100
DEV_API_PORT=8000
