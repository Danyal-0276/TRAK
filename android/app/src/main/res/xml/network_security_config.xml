<?xml version="1.0" encoding="utf-8"?>
<!-- Allow HTTP to local dev API (LAN / emulator). Tighten before store release if needed. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
